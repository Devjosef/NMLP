cat > .gitignore << 'EOF'
# Bytecode cache
__pycache__/
__pycache__/*
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Outputs 
outputs/
*.csv
*.json
*.log

# Local Database Storage
ploss_analytics.db
ploss_analytics.db-journal

# Testing
.pytest_cache/
.coverage
.coverage.*
.tox/
.hypothesis/
.nox/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Distribution
dist/
build/
*.egg
*.egg-info/
MANIFEST

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Misc
*.log
.env
EOF
